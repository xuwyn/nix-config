#!/usr/bin/env bash
set -euo pipefail

mkdir -p /btrfs_tmp
mount -o subvol=/ /dev/mapper/cryptroot /btrfs_tmp

delete_subvolume_recursively() {
  local i
  for i in $(btrfs subvolume list -o "$1" | cut -f 9- -d ' '); do
    delete_subvolume_recursively "/btrfs_tmp/$i"
  done
  btrfs subvolume delete "$1"
}

if [[ -d /btrfs_tmp/old_roots ]]; then
  shopt -s nullglob
  snapshots=(/btrfs_tmp/old_roots/*/)
  shopt -u nullglob

  if [[ ${#snapshots[@]} -eq 0 ]]; then
    echo "No old_roots snapshots found, nothing to clean."
  else
    echo "The following snapshots will be permanently deleted:"
    for snap in "${snapshots[@]}"; do
      echo "  - ${snap%/}"
    done

    read -rp "Proceed with deletion? [y/N] " confirm
    if [[ "$confirm" =~ ^[Yy]$ ]]; then
      for snap in "${snapshots[@]}"; do
        echo "Deleting snapshot: $snap"
        delete_subvolume_recursively "${snap%/}"
      done
    else
      echo "Aborted, no snapshots were deleted."
    fi
  fi
else
  echo "No old_roots directory found, nothing to clean."
fi

umount /btrfs_tmp
